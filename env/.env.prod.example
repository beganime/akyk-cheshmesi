APP_ENV=production
DJANGO_SETTINGS_MODULE=config.settings

DJANGO_SECRET_KEY=CHANGE_ME
JWT_SECRET=CHANGE_ME
GO_JWT_SECRET=CHANGE_ME

DJANGO_DEBUG=False
DJANGO_TIME_ZONE=Asia/Ashgabat
DJANGO_ALLOWED_HOSTS=akyl-cheshmesi.ru,www.akyl-cheshmesi.ru,akylcheshmesi.ru,www.akylcheshmesi.ru,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://akyl-cheshmesi.ru,https://www.akyl-cheshmesi.ru,https://akylcheshmesi.ru,https://www.akylcheshmesi.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://akyl-cheshmesi.ru,https://www.akyl-cheshmesi.ru,https://akylcheshmesi.ru,https://www.akylcheshmesi.ru

POSTGRES_DB=akyl_chat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/akyl_chat
GO_DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/akyl_chat
DB_CONN_MAX_AGE=60

REDIS_CACHE_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1
REDIS_STREAM_URL=redis://redis:6379/1
REDIS_HISTORY_URL=redis://redis:6379/2

ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=14

DEFAULT_FROM_EMAIL="Akyl Cheshmesi <no-reply@akyl-cheshmesi.ru>"
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_HOST_USER=MY_EMAIL
EMAIL_HOST_PASSWORD=MY_PASSWORD
EMAIL_USE_SSL=True

USE_S3=True
AWS_STORAGE_BUCKET_NAME=CHANGE_ME
AWS_S3_ENDPOINT_URL=https://s3.regru.cloud
AWS_S3_REGION_NAME=RU
AWS_ACCESS_KEY_ID=YOUR_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False

REDIS_PROFILE_TTL_SECONDS=86400
REDIS_CHAT_TTL_SECONDS=86400
REDIS_HISTORY_LIST_LIMIT=50
REDIS_HISTORY_TTL_SECONDS=604800
REDIS_PRESENCE_TTL_SECONDS=90
REDIS_STREAM_MESSAGES_KEY=stream:messages
REDIS_STREAM_MESSAGES_GROUP=message-savers
REDIS_STREAM_DLQ_KEY=stream:messages:dlq
REDIS_STREAM_READ_COUNT=20
REDIS_STREAM_BLOCK_MS=5000
REDIS_STREAM_CLAIM_IDLE_MS=60000
REDIS_STREAM_MESSAGE_STATUS_KEY=stream:message-statuses
REDIS_STREAM_MESSAGE_STATUS_GROUP=message-status-savers
REDIS_STREAM_MESSAGE_STATUS_DLQ_KEY=stream:message-statuses:dlq
REDIS_REALTIME_EVENTS_CHANNEL=realtime:events

GO_ENV=production
GO_HTTP_HOST=0.0.0.0
GO_HTTP_PORT=8081
GO_REDIS_CACHE_URL=redis://redis:6379/0
GO_REDIS_STREAM_URL=redis://redis:6379/1
GO_WS_READ_LIMIT=8192
GO_WS_WRITE_BUFFER=256
GO_ALLOWED_ORIGINS=https://akyl-cheshmesi.ru,https://www.akyl-cheshmesi.ru,https://akylcheshmesi.ru,https://www.akylcheshmesi.ru
GO_RATE_LIMIT_MESSAGES_PER_10S=12
GO_RATE_LIMIT_TYPING_PER_10S=30
GO_RATE_LIMIT_STATUSES_PER_10S=40
GO_CALL_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
GO_CALL_TURN_URLS=
GO_CALL_TURN_USERNAME=
GO_CALL_TURN_CREDENTIAL=
GO_CALL_MAX_PEERS_PER_ROOM=8
GO_CALL_CLEANUP_INTERVAL_SECONDS=15
GO_CALL_EMPTY_ROOM_TTL_SECONDS=30
GO_CALL_WS_READ_LIMIT=65536

MEDIA_MAX_UPLOAD_SIZE_BYTES=26214400
MAX_UPLOAD_SIZE_MB=25
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1920
IMAGE_THUMBNAIL_SIZE=480
IMAGE_UPLOAD_QUALITY=82
VIDEO_MAX_SIZE_MB=100
VIDEO_MAX_DURATION_SECONDS=600
VIDEO_NOTE_MAX_SIZE_MB=50
VIDEO_NOTE_MAX_DURATION_SECONDS=60
AUDIO_MAX_SIZE_MB=25
AUDIO_MAX_DURATION_SECONDS=300
STORY_TTL_HOURS=24
MEDIA_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/quicktime,video/webm,audio/mpeg,audio/wav,audio/x-wav,audio/mp4,audio/aac,audio/webm,audio/ogg,application/pdf,text/plain,text/csv,application/zip,application/x-zip-compressed,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/octet-stream
SECURE_COOKIES=True
ENABLE_SECURITY_HEADERS=True
SECURE_SSL_REDIRECT=False
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60
CELERY_LOGLEVEL=INFO


AWS_S3_VERIFY=/etc/ssl/certs/ca-certificates.crt
AWS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

FCM_PROJECT_ID=akylcheshmesi-push
FCM_SERVICE_ACCOUNT_FILE=/app/secrets/firebase-service-account.json

TASKS_EAGER=False
DJANGO_DEBUG=False

AWS_S3_PUBLIC_READ=False
AWS_S3_PRESIGNED_GET_EXPIRES=3600
